# Environment Variables for EnglishBolo
# Copy this file to .env and modify as needed

# Server Configuration
BACKEND_HOST=localhost
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Model Configuration
WHISPER_MODEL=tiny  # Options: tiny, base, small, medium, large
LANGUAGE=en-US

# FFmpeg Configuration
FFMPEG_PATH=ffmpeg  # Use 'ffmpeg' if in PATH, or provide full path

# Logging
LOG_LEVEL=INFO
